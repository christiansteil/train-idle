@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<style>
	.screen {
		width: 100%;
		height: 100%;
		background-color: #111;
		color: white;
		font-size: 24px;
		flex-direction: column;
		pointer-events: all;
	}

	.top-bar {
		height: 80px;
		width: 100%;
		background-color: #1b1b1b;
		padding: 16px 32px;
		align-items: center;
		justify-content: space-between;
	}

	.title {
		font-size: 36px;
		font-weight: bold;
	}

	.money-bar {
		gap: 32px;
		align-items: center;
	}

	.stat {
		font-size: 28px;
		font-weight: bold;
	}

	.main {
		flex-grow: 1;
		width: 100%;
		padding: 32px;
		gap: 32px;
		flex-direction: row;
	}

	.panel {
		background-color: #222;
		border-radius: 16px;
		padding: 32px;
		flex-direction: column;
		gap: 16px;
	}

	.train-panel {
		flex-grow: 1;
		position: relative;
	}

	.train-counts {
		position: absolute;
		right: 32px;
		top: 32px;
		align-items: flex-end;
		flex-direction: column;
		gap: 8px;
	}

	.shop-panel {
		width: 420px;
	}

	h2 {
		font-size: 40px;
		margin-bottom: 12px;
	}

	button {
		font-size: 24px;
		padding: 16px 24px;
		background-color: #444;
		color: white;
		border-radius: 8px;
	}

	.get-a-job-button {
		width: 160px;
		height: 64px;
		align-self: flex-start;
	}

	.can-afford:hover {
		background-color: #333;
	}

	.can-afford:active {
		transform: scale( 0.96 );
	}

	.cant-afford {
		opacity: 0.4;
	}
</style>

<root>
	<div class="screen">
		<div class="top-bar">
			<div class="title">Train Idle</div>

			<div class="money-bar">
				<div class="stat">Money: $@FormatNumber( Game?.Money ?? 0 )</div>
				<div class="stat">Money per second: $@FormatNumber( Game?.MoneyPerSecond ?? 0 )</div>
			</div>
		</div>

		<div class="main">
			<div class="panel train-panel">
				<div class="train-counts">
					<div>Trains: @(Game?.Trains ?? 0) / 1</div>
					<div>Train Cars: @(Game?.TrainCars ?? 0)</div>
				</div>

				<button class="get-a-job-button can-afford" onclick="@ClickMoney">Get a Job</button>
			</div>

			<div class="panel shop-panel">
				<h2>Shop</h2>

				@if ( Game is not null && Game.Trains < 1 )
				{
					<button class="@GetButtonClass( Game.CanBuyTrain() )" onclick="@BuyTrain" disabled="@(!Game.CanBuyTrain())">
						Buy Train - $@FormatNumber( Game.TrainCost )
					</button>
				}
				else if ( Game is not null )
				{
					<button class="@GetButtonClass( Game.CanBuyTrainCar() )" onclick="@BuyTrainCar" disabled="@(!Game.CanBuyTrainCar())">
						Buy Train Car - $@FormatNumber( Game.TrainCarCost )
					</button>
				}
			</div>
		</div>
	</div>
</root>

@code
{
	private Logic Game;

	protected override void OnStart()
	{
		Game = Scene.GetAllComponents<Logic>().FirstOrDefault();
	}

	void BuyTrain()
	{
		Game?.BuyTrain();
		StateHasChanged();
	}

	void BuyTrainCar()
	{
		Game?.BuyTrainCar();
		StateHasChanged();
	}

	void ClickMoney()
	{
		Game.Money++;
		StateHasChanged();
	}

	string FormatNumber( double number )
	{
		return number.ToString( "0.0" );
	}

	string GetButtonClass( bool canBuy )
	{
	return canBuy ? "can-afford" : "cant-afford";
	}

	protected override int BuildHash()
	{
		return System.HashCode.Combine(
			Game?.Money ?? 0,
			Game?.Trains ?? 0,
			Game?.TrainCars ?? 0,
			Game?.MoneyPerSecond ?? 0
		);
	}
}