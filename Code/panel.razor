@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<style>
	.screen {
		width: 100%;
		height: 100%;
		background-color: #111;
		color: white;
		font-size: 32px;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		pointer-events: all;
	}

	h1 {
		font-size: 64px;
		margin-bottom: 32px;
	}

	button {
		font-size: 28px;
		padding: 16px 32px;
		margin-bottom: 24px;
	}
</style>

<root>
	<div class="screen">
		<h1>Maintenance</h1>
		<button onclick="@CrankWheel">Crank Wheel</button>
		<div>Energy: @Energy</div>
	</div>
</root>

@code
{
	public int Energy { get; set; } = 0;

	void CrankWheel()
	{
		Energy++;
		StateHasChanged();
	}

	protected override int BuildHash()
	{
		return System.HashCode.Combine( Energy );
	}
}