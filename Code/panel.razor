@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<style>
	.screen {
		width: 100%;
		height: 100%;
		background-color: #111;
		color: white;
		font-size: 32px;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		pointer-events: all;
	}

	h1 {
		font-size: 64px;
		margin-bottom: 32px;
	}

	button {
		font-size: 28px;
		padding: 16px 32px;
		margin-bottom: 24px;
	}
</style>

<root>
	<div class="screen">
		<h1>Train Idle</h1>

		<button onclick="@ClickMoney">Get a Job</button>

		<div>Money: @Game?.Money.ToString("0")</div>
		<div>Income: @Game?.MoneyPerSecond.ToString("0.0") / sec</div>
	</div>
</root>

@code
{
	private Logic Game;

	protected override void OnStart()
	{
		Game = Scene.GetAllComponents<Logic>().FirstOrDefault();
	}

	void ClickMoney()
	{
		Game.Money++;
		StateHasChanged();
	}

	protected override int BuildHash()
	{
		return System.HashCode.Combine(
			Game.Money,
			Game.MoneyPerSecond
		);
	}
}