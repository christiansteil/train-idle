@using Sandbox;
@using System;
@using System.Collections.Generic;
@using System.Linq;
@using Sandbox.UI;
@attribute [StyleSheet( "Panel.razor.scss" )]
@inherits PanelComponent

<root>
	<div class="screen">
		<div class="top-bar">
			<div class="title">Train Idle</div>

			<div class="money-bar">
				<div class="stat">Money: $@FormatNumber( Game?.Money ?? 0 )</div>
				<div class="stat">Money per second: $@FormatNumber( Game?.MoneyPerSecond ?? 0 )</div>
			</div>
		</div>

		<div class="content">
			<div class="side-menu">
				<button class="menu-button @GetTabClass( "Trains" )" onclick="@(() => SetTab( "Trains" ))">
					Trains
				</button>

				<button class="menu-button @GetTabClass( "Routes" )" onclick="@(() => SetTab( "Routes" ))">
					Routes
				</button>
				<button class="menu-button @GetTabClass( "Research" )" onclick="@(() => SetTab( "Research" ))">
					Research
				</button>
				<button class="menu-button @GetTabClass( "Stats" )" onclick="@(() => SetTab( "Stats" ))">
					Stats
				</button>
			</div>

			@if ( CurrentTab == "Trains" )
			{
				<div class="main">
					<div class="top-row">
						<div class="panel train-panel">
							<div class="train-counts">
								<div>Trains: @(Game?.Trains ?? 0) / 1</div>
								<div>Train Cars: @(Game?.TrainCars ?? 0)</div>
							</div>

							<div class="job-button-area">
								<button class="get-a-job-button can-afford" onclick="@ClickMoney">
									Get a Job
								</button>
							</div>
						</div>

						<div class="panel shop-panel">
							<h2>Shop</h2>

							@if ( Game is not null && Game.Trains < 1 )
							{
								<button class="@GetButtonClass( Game.CanBuyTrain() )" onclick="@BuyTrain" disabled="@(!Game.CanBuyTrain())">
									Buy Train - $@FormatNumber( Game.TrainCost )
								</button>
							}
							else if ( Game is not null )
							{
								<button class="@GetButtonClass( Game.CanBuyTrainCar() )" onclick="@BuyTrainCar" disabled="@(!Game.CanBuyTrainCar())">
									Buy Train Car - $@FormatNumber( Game.TrainCarCost )
								</button>
							}
						</div>
					</div>

					<div class="panel fuel-panel">
						<h2>Fuel</h2>

						<div class="fuel-description">
							Add fuel to increase the speed of your trains, increasing profits.
						</div>

						<div class="fuel-stats">
							<div>Coal: @FormatNumber( Game?.Coal ?? 0 )</div>
							<div>Coal miners: @(Game?.CoalMiners ?? 0)</div>
							<div>Coal production: @FormatNumber( Game?.CoalPerSecond ?? 0 ) / sec</div>
							<div>Train speed: @($"x{FormatNumber( Game?.CoalIncomeMultiplier ?? 0 )}")</div>
						</div>

						@if ( Game is not null )
						{
							<button class="@GetButtonClass( Game.CanBuyCoalMiner() )" onclick="@BuyCoalMiner" disabled="@(!Game.CanBuyCoalMiner())">
								Buy Coal Miner - $@FormatNumber( Game.CoalMinerCost )
							</button>
						}
					</div>
				</div>
			}
			else if ( CurrentTab == "Routes" )
			{
				<div class="main">
					<div class="panel routes-panel">
						<h2>Routes</h2>

						<div class="route-view">
							@for ( int i = 0; i < RouteTrackPieceCount; i++ )
							{
								<div class="track-piece" style="@GetTrackPieceStyle( i )"></div>
							}

							<div class="station station-a">A</div>
							<div class="station station-b">B</div>

							@if ( Game is not null && Game.Trains > 0 )
							{
								<div class="route-piece train-engine" style="@GetRoutePieceStyle( 0, true )"></div>

								@for ( int i = 1; i <= GetVisibleTrainCars(); i++ )
								{
									<div class="route-piece train-car" style="@GetRoutePieceStyle( i, false )"></div>
								}
							}
						</div>

						<div class="route-stats">
							<div>Route: Loop Line</div>
							<div>Train speed: @($"x{FormatNumber( Game?.CoalIncomeMultiplier ?? 0 )}")</div>
							<div>Visible cars: @GetVisibleTrainCars() / @(Game?.TrainCars ?? 0)</div>
						</div>
					</div>
				</div>
			}
			else if ( CurrentTab == "Stats" )
			{
				<div class="main">
					<div class="panel stats-panel">
						<h2>Stats</h2>

						<div class="stats-section">
							<h3>Money Income</h3>

							<div class="equation-row">
								<div>Money per second =</div>

								<div class="equation-term">
									@FormatNumber( Game?.TrainCars ?? 0 )
									<div class="tooltip"># train cars</div>
								</div>

								<div class="equation-symbol">*</div>

								<div class="equation-term">
									@FormatNumber( GetTrainCarIncome() )
									<div class="tooltip">money per train car</div>
								</div>

								<div class="equation-symbol">*</div>

								<div class="equation-term">
									@FormatNumber( Game?.CoalIncomeMultiplier ?? 1 )
									<div class="tooltip">train speed from coal</div>
								</div>

								<div class="equation-symbol">=</div>

								<div class="equation-result">
									@($"${FormatNumber( Game?.MoneyPerSecond ?? 0 )} / sec")
								</div>
							</div>
						</div>

						<div class="stats-section">
							<h3>Train Speed</h3>

							<div class="equation-row">
								<div>Train speed =</div>

								<div class="equation-symbol">1 + log10(</div>

								<div class="equation-term">
									@FormatNumber( Game?.Coal ?? 0 )
									<div class="tooltip">coal</div>
								</div>

								<div class="equation-symbol">+ 1) *</div>

								<div class="equation-term">
									@FormatNumber( GetCoalSpeedStrength() )
									<div class="tooltip">coal speed strength</div>
								</div>

								<div class="equation-symbol">=</div>

								<div class="equation-result">
									@($"x{FormatNumber( Game?.CoalIncomeMultiplier ?? 1 )}")
								</div>
							</div>
						</div>

						<div class="stats-section">
							<h3>Coal Income</h3>

							<div class="equation-row">
								<div>Coal per second =</div>

								<div class="equation-term">
									@FormatNumber( Game?.CoalMiners ?? 0 )
									<div class="tooltip"># coal miners</div>
								</div>

								<div class="equation-symbol">*</div>

								<div class="equation-term">
									@FormatNumber( GetCoalMinerIncome() )
									<div class="tooltip">coal per miner</div>
								</div>

								<div class="equation-symbol">=</div>

								<div class="equation-result">
									@($"{FormatNumber( Game?.CoalPerSecond ?? 0 )} coal / sec")
								</div>
							</div>
						</div>

						<div class="stats-section">
							<h3>Resources</h3>

							<div class="equation-row">
								<div>Total coal =</div>

								<div class="equation-result">
									@FormatNumber( Game?.Coal ?? 0 )
								</div>
							</div>

							<div class="equation-row">
								<div>Total train cars =</div>

								<div class="equation-result">
									@FormatNumber( Game?.TrainCars ?? 0 )
								</div>
							</div>

							<div class="equation-row">
								<div>Total coal miners =</div>

								<div class="equation-result">
									@FormatNumber( Game?.CoalMiners ?? 0 )
								</div>
							</div>
						</div>
					</div>
				</div>
			}
			else if ( CurrentTab == "Research" )
			{
				<div class="main">
					<div class="panel research-panel">
						<h2>Research</h2>

						<div class="research-total">
							@($"Research: {FormatNumber( Game?.Research ?? 0 )}")
						</div>

						<div class="research-description">
							Your train gains research whenever it reaches Point B on the route.
						</div>

						<div class="stats-section">
							<h3>Research Income</h3>

							<div class="equation-row">
								<div>Research per second =</div>

								<div class="equation-term">
									@FormatNumber( GetArrivalsAtBPerSecond() )
									<div class="tooltip">arrivals at Point B per second</div>
								</div>

								<div class="equation-symbol">*</div>

								<div class="equation-term">
									@FormatNumber( GetResearchPerArrivalAtB() )
									<div class="tooltip">research gained per Point B arrival</div>
								</div>

								<div class="equation-symbol">=</div>

								<div class="equation-result">
									@($"{FormatNumber( GetResearchPerSecond() )} research / sec")
								</div>
							</div>
						</div>

						<div class="stats-section">
							<h3>Research Per Arrival</h3>

							<div class="equation-row">
								<div>Research per Point B arrival =</div>

								<div class="equation-term">
									@FormatNumber( Game?.TrainCars ?? 0 )
									<div class="tooltip"># train cars</div>
								</div>

								<div class="equation-symbol">*</div>

								<div class="equation-term">
									@FormatNumber( GetResearchPerTrainCar() )
									<div class="tooltip">research per train car</div>
								</div>

								<div class="equation-symbol">=</div>

								<div class="equation-result">
									@($"{FormatNumber( GetResearchPerArrivalAtB() )} research")
								</div>
							</div>
						</div>

						<div class="stats-section">
							<h3>Point B Arrivals</h3>

							<div class="equation-row">
								<div>Arrivals at Point B per second =</div>

								<div class="equation-term">
									@FormatNumber( Game?.VisualTrainSpeed ?? 0 )
									<div class="tooltip">route progress per second</div>
								</div>

								<div class="equation-symbol">=</div>

								<div class="equation-result">
									@($"{FormatNumber( GetArrivalsAtBPerSecond() )} arrivals / sec")
								</div>
							</div>
						</div>

						<div class="stats-section">
							<h3>Speed Source</h3>

							<div class="equation-row">
								<div>Route speed =</div>

								<div class="equation-term">
									@FormatNumber( 0.08 )
									<div class="tooltip">base route speed</div>
								</div>

								<div class="equation-symbol">*</div>

								<div class="equation-term">
									@FormatNumber( Game?.CoalIncomeMultiplier ?? 1 )
									<div class="tooltip">train speed from coal</div>
								</div>

								<div class="equation-symbol">=</div>

								<div class="equation-result">
									@($"{FormatNumber( Game?.VisualTrainSpeed ?? 0 )} route progress / sec")
								</div>
							</div>
						</div>
					</div>
				</div>
			}
		</div>

		@foreach ( var text in FloatingTexts )
		{
			<div class="floating-money" style="@GetFloatingTextStyle( text )">
				@text.Text
			</div>
		}

		@if ( Game is not null && Game.ShowOfflinePopup )
		{
			<div class="popup-backdrop">
				<div class="popup-window">
					<h2>Welcome Back!</h2>

					<div>@($"You were offline for {FormatTime( Game.LastOfflineSeconds )}.")</div>
					<div>@($"You earned ${FormatNumber( Game.LastOfflineMoneyEarned )}.")</div>

					<button class="can-afford" onclick="@CloseOfflinePopup">
						Close
					</button>
				</div>
			</div>
		}
	</div>
</root>

@code
{
	private Logic Game;
	private string CurrentTab = "Trains";

	private readonly List<FloatingText> FloatingTexts = new();
	private int NextFloatingTextId = 0;

	private const float FloatingTextLifetime = 0.8f;

	private const int RouteTrackPieceCount = 64;
	private const int RouteSampleCount = 240;

	private const float RouteCenterX = 520f;
	private const float RouteCenterY = 260f;
	private const float RouteRadiusX = 420f;
	private const float RouteRadiusY = 190f;

	private float[] CachedEvenRouteProgresses;
	private float[] CachedRouteDistances;
	private float CachedRouteTotalDistance;

	class FloatingText
	{
		public int Id { get; set; }
		public string Text { get; set; } = "";
		public TimeSince Age { get; set; }
		public Vector2 Position { get; set; }
	}

	struct RoutePoint
	{
		public float X;
		public float Y;
		public float Rotation;
	}

	protected override void OnStart()
	{
		Game = Scene.GetAllComponents<Logic>().FirstOrDefault();
		BuildRouteCache();
	}

	void SetTab( string tab )
	{
		CurrentTab = tab;
		StateHasChanged();
	}

	string GetTabClass( string tab )
	{
		return CurrentTab == tab ? "active-tab" : "";
	}

	void BuyTrain()
	{
		Game?.BuyTrain();
		StateHasChanged();
	}

	void BuyTrainCar()
	{
		Game?.BuyTrainCar();
		StateHasChanged();
	}

	void BuyCoalMiner()
	{
		Game?.BuyCoalMiner();
		StateHasChanged();
	}

	void ClickMoney()
	{
		if ( Game is null )
			return;

		Game.ClickMoney();

		FloatingTexts.Add( new FloatingText
		{
			Id = NextFloatingTextId++,
			Text = "+1",
			Age = 0,
			Position = Mouse.Position
		} );

		StateHasChanged();
	}

	void CloseOfflinePopup()
	{
		Game?.CloseOfflinePopup();
		StateHasChanged();
	}

	string GetButtonClass( bool canBuy )
	{
		return canBuy ? "can-afford" : "cant-afford";
	}

	string GetFloatingTextStyle( FloatingText text )
	{
		float age = text.Age;
		float progress = Math.Clamp( age / FloatingTextLifetime, 0f, 1f );

		float y = -40f * progress;
		float opacity = 1f - progress;

		float x = text.Position.x / 1.63f;
		float startY = text.Position.y / 7.5f;

		return $"left: {x}px; top: {startY}px; transform: translate(-50%, -50%) translateY({y}px); opacity: {opacity};";
	}

	int GetVisibleTrainCars()
	{
		if ( Game is null )
			return 0;

		return Game.TrainCars;
	}

	float GetTrainPieceScale()
	{
		int visibleCars = GetVisibleTrainCars();

		if ( visibleCars <= 10 )
			return 1.0f;

		if ( visibleCars <= 25 )
			return 0.75f;

		return 0.55f;
	}

	double GetTrainCarIncome()
	{
		return 1.0;
	}

	double GetCoalMinerIncome()
	{
		return 1.0;
	}

	double GetCoalSpeedStrength()
	{
		return 0.5;
	}

	double GetResearchPerTrainCar()
	{
		return 1.0;
	}

	double GetResearchPerArrivalAtB()
	{
		if ( Game is null )
			return 0;

		return Game.TrainCars * GetResearchPerTrainCar();
	}

	double GetArrivalsAtBPerSecond()
	{
		if ( Game is null )
			return 0;

		return Game.VisualTrainSpeed;
	}

	double GetResearchPerSecond()
	{
		return GetArrivalsAtBPerSecond() * GetResearchPerArrivalAtB();
	}

	Vector2 GetRoutePositionOnly( float progress )
	{
		progress = progress - MathF.Floor( progress );

		float angle = progress * MathF.PI * 2f;

		float x = RouteCenterX + MathF.Cos( angle ) * RouteRadiusX;
		float y = RouteCenterY + MathF.Sin( angle ) * RouteRadiusY;

		return new Vector2( x, y );
	}

	RoutePoint GetRoutePoint( float progress )
	{
		progress = progress - MathF.Floor( progress );

		float angle = progress * MathF.PI * 2f;

		float x = RouteCenterX + MathF.Cos( angle ) * RouteRadiusX;
		float y = RouteCenterY + MathF.Sin( angle ) * RouteRadiusY;

		float dx = -MathF.Sin( angle ) * RouteRadiusX;
		float dy = MathF.Cos( angle ) * RouteRadiusY;

		float rotation = MathF.Atan2( dy, dx ) * 180f / MathF.PI;

		return new RoutePoint
		{
			X = x,
			Y = y,
			Rotation = rotation
		};
	}

	void BuildRouteCache()
	{
		CachedRouteDistances = new float[RouteSampleCount + 1];
		CachedEvenRouteProgresses = new float[RouteTrackPieceCount];

		float totalDistance = 0f;
		Vector2 previousPoint = GetRoutePositionOnly( 0f );

		CachedRouteDistances[0] = 0f;

		for ( int i = 1; i <= RouteSampleCount; i++ )
		{
			float progress = i / (float)RouteSampleCount;
			Vector2 point = GetRoutePositionOnly( progress );

			totalDistance += Vector2.DistanceBetween( previousPoint, point );
			CachedRouteDistances[i] = totalDistance;

			previousPoint = point;
		}

		CachedRouteTotalDistance = totalDistance;

		for ( int i = 0; i < RouteTrackPieceCount; i++ )
		{
			float distanceProgress = i / (float)RouteTrackPieceCount;
			CachedEvenRouteProgresses[i] = GetEvenRouteProgressFromCache( distanceProgress );
		}
	}

	float GetEvenRouteProgressWrapped( float distanceProgress )
	{
		distanceProgress = distanceProgress - MathF.Floor( distanceProgress );
		return GetEvenRouteProgressFromCache( distanceProgress );
	}

	float GetEvenRouteProgressFromCache( float distanceProgress )
	{
		if ( CachedRouteDistances is null || CachedRouteDistances.Length == 0 )
			BuildRouteCache();

		distanceProgress = distanceProgress - MathF.Floor( distanceProgress );

		float targetDistance = distanceProgress * CachedRouteTotalDistance;

		for ( int i = 1; i <= RouteSampleCount; i++ )
		{
			if ( CachedRouteDistances[i] < targetDistance )
				continue;

			float previousDistance = CachedRouteDistances[i - 1];
			float nextDistance = CachedRouteDistances[i];

			float segmentPercent = 0f;

			if ( nextDistance > previousDistance )
				segmentPercent = (targetDistance - previousDistance) / (nextDistance - previousDistance);

			float previousProgress = (i - 1) / (float)RouteSampleCount;
			float nextProgress = i / (float)RouteSampleCount;

			return previousProgress + (nextProgress - previousProgress) * segmentPercent;
		}

		return 0f;
	}

	string GetTrackPieceStyle( int index )
	{
		if ( CachedEvenRouteProgresses is null || CachedEvenRouteProgresses.Length == 0 )
			BuildRouteCache();

		float progress = CachedEvenRouteProgresses[index];
		RoutePoint point = GetRoutePoint( progress );

		return $"left: {point.X}px; top: {point.Y}px; transform: translate(-50%, -50%) rotate({point.Rotation}deg);";
	}

	string GetRoutePieceStyle( int index, bool isEngine )
	{
		if ( Game is null )
			return "";

		float scale = GetTrainPieceScale();

		float spacing = 0.018f;

		if ( scale < 1.0f )
			spacing *= scale;

		float distanceProgress = Game.RouteProgress - index * spacing;
		float routeProgress = GetEvenRouteProgressWrapped( distanceProgress );

		RoutePoint point = GetRoutePoint( routeProgress );

		float width = isEngine ? 38f : 28f;
		float height = isEngine ? 26f : 20f;

		width *= scale;
		height *= scale;

		return $"left: {point.X}px; top: {point.Y}px; width: {width}px; height: {height}px; transform: translate(-50%, -50%) rotate({point.Rotation}deg);";
	}

	string FormatTime( double seconds )
	{
		int totalSeconds = (int)Math.Floor( seconds );

		int hours = totalSeconds / 3600;
		int minutes = (totalSeconds % 3600) / 60;
		int secs = totalSeconds % 60;

		if ( hours > 0 )
			return $"{hours}h {minutes}m {secs}s";

		if ( minutes > 0 )
			return $"{minutes}m {secs}s";

		if ( seconds < 10 )
			return $"{seconds:0.0}s";

		return $"{secs}s";
	}

	string FormatNumber( double number )
	{
		return number.ToString( "0.0" );
	}

	protected override int BuildHash()
	{
		FloatingTexts.RemoveAll( text => text.Age > FloatingTextLifetime );

		bool shouldAnimate = FloatingTexts.Count > 0 || CurrentTab == "Routes";

		int animationFrame = shouldAnimate
			? (int)(RealTime.Now * 30)
			: 0;

		int animationHash = System.HashCode.Combine(
			FloatingTexts.Count,
			animationFrame
		);

		int fuelHash = System.HashCode.Combine(
			Game?.Coal ?? 0,
			Game?.CoalMiners ?? 0,
			Game?.CoalPerSecond ?? 0,
			Game?.CoalIncomeMultiplier ?? 1
		);

		int tabHash = CurrentTab.GetHashCode();

		int routeHash = System.HashCode.Combine(
			Game?.TrainCars ?? 0
		);

		int researchHash = System.HashCode.Combine(
			Game?.Research ?? 0,
			Game?.ResearchPerArrival ?? 0
		);

		int extraHash = System.HashCode.Combine(
			animationHash,
			fuelHash,
			tabHash,
			routeHash,
			researchHash
		);

		return System.HashCode.Combine(
			Game?.Money ?? 0,
			Game?.Trains ?? 0,
			Game?.TrainCars ?? 0,
			Game?.MoneyPerSecond ?? 0,
			Game?.ShowOfflinePopup ?? false,
			Game?.LastOfflineMoneyEarned ?? 0,
			Game?.LastOfflineSeconds ?? 0,
			extraHash
		);
	}
}